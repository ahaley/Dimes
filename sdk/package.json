{
  "name": "dimes-capture-sdk",
  "version": "0.1.0",
  "description": "Embeddable latent-observation capture SDK for Dimes",
  "license": "MIT",
  "author": "Antonio Haley",
  "homepage": "https://github.com/ahaley/Dimes/tree/main/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahaley/Dimes.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/ahaley/Dimes/issues"
  },
  "keywords": [
    "dimes",
    "capture",
    "observations",
    "feedback",
    "telemetry",
    "rum",
    "error-tracking",
    "sdk"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
