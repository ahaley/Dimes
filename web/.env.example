# Dimes web dev-server config. Copy to `.env` (gitignored) and uncomment to override.
#
# Where the Vite dev server proxies /api, /openapi, /hubs, and /signin-oidc.
# Defaults to http://localhost:5080 (what `dotnet run --project src/Dimes.Api` binds).
# Set this only if you run the API on a different host/port.
# DIMES_API=http://localhost:5080
