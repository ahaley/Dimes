{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Authentication is a per-deployment choice. Mode = "Local" (email + password) or "Oidc" (Keycloak).
  // Provide the site admin and (for Oidc) the provider settings via environment variables or a
  // non-committed appsettings.Production.json. The OIDC ClientSecretRef is resolved through the secret
  // store (Secrets:{ref} or an env var of that name) — never put the secret itself here.
  // "Auth": {
  //   "Mode": "Oidc",
  //   "SiteAdmin": { "Email": "admin@example.com" },
  //   "Oidc": {
  //     "Authority": "https://keycloak.example.com/realms/dimes",
  //     "ClientId": "dimes",
  //     "ClientSecretRef": "DIMES_OIDC_CLIENT_SECRET",
  //     "CallbackPath": "/signin-oidc",
  //     "Scopes": "openid email profile"
  //   }
  // },
  "Auth": {
    "Mode": "Local"
  },

  // Cross-origin access for the capture SDK (dimes-capture-sdk). Only the anonymous observation
  // ingest endpoint honors these origins; every other endpoint stays same-origin. List the exact
  // origins (scheme + host + port) of host apps that embed the SDK from a different domain.
  // Credentials are never allowed. Unset/empty => no cross-origin access. Set via env as e.g.
  // Cors__AllowedOrigins__0=https://app.example.com  Cors__AllowedOrigins__1=https://other.example.com
  // "Cors": {
  //   "AllowedOrigins": [ "https://app.example.com" ]
  // }
}
